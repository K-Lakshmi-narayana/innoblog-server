# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/innoblog

# Mail
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password

# JWT
JWT_SECRET=your-secret-key-change-this-in-production

# Admin Email (optional, defaults to MAIL_USER)
ADMIN_EMAIL=admin@example.com

# Frontend URL (for CORS) - set this to your deployed frontend URL
# Example: https://innoblog-client.vercel.app
FRONTEND_URL=https://innoblog-client.vercel.app

# Public API URL used when returning image links
# Local example: http://localhost:4000
PUBLIC_API_URL=https://api.example.com

# Filesystem upload root for cover and article images
# Windows pendrive example: E:/blog-images
# Linux example: /var/www/uploads
# Local fallback if omitted: server/uploads
UPLOAD_ROOT=/var/www/uploads

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-from-console
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Environment
NODE_ENV=production
PORT=4000
